# ROOT — MERN Monorepo .gitignore

# Dependencies (Backend + Frontend)

node_modules/
backend/node_modules/
frontend/node_modules/

# Environment Variables (SECRETS)

.env
backend/.env
frontend/.env

# Logs

logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build Outputs

dist/
build/
frontend/dist/
backend/dist/

# Vite / React Cache

frontend/.vite/
.vite/
.cache/

# Uploads (User files)

backend/uploads/
uploads/

# Database files (if local)

*.db
*.sqlite
data/

# Coverage

coverage/

# OS Files

.DS_Store
Thumbs.db

# Editor / IDE Files

.vscode/
.idea/
*.swp
*.swo

# Firebase / credentials (if any)

firebase-debug.log
.firebaserc

# Temporary files

tmp/
temp/

# TypeScript cache (if used later)

*.tsbuildinfo